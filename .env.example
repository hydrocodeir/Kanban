# کپی کنید به .env و مقدارها را تنظیم کنید
APP_NAME="کانبان فارسی"
ENV="dev"
SECRET_KEY="change-me"

# MySQL: مثال
# mysql+pymysql://USER:PASSWORD@HOST:3306/kanban_db?charset=utf8mb4
DATABASE_URL="mysql+pymysql://kanban:kanban@127.0.0.1:3306/kanban_db?charset=utf8mb4"

# Redis: مثال
REDIS_URL="redis://127.0.0.1:6379/0"

# کاربر نمونه (برای نسخه مینیمال بدون احراز هویت)
DEFAULT_USER_EMAIL="demo@example.com"
DEFAULT_USER_NAME="کاربر نمونه"

# در صورت نیاز (مخصوص داکر/توسعه)
AUTO_INIT_DB="false"
